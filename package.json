{
  "name": "@paysponge/sdk",
  "version": "0.1.54",
  "type": "module",
  "description": "SDK for spinning up wallets for AI agents with Claude Agent SDK integration",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cli": {
      "import": "./dist/cli.js",
      "types": "./dist/cli.d.ts"
    }
  },
  "bin": {
    "spongewallet": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "generate:api": "bash ../../scripts/generate-sdk-clients.sh ts",
    "generate:python": "bash ../../scripts/generate-sdk-clients.sh python",
    "generate": "bun run generate:api",
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json",
    "test": "vitest run",
    "check": "bun run generate && bun run typecheck && bun run typecheck:examples && bun test",
    "test:watch": "vitest",
    "prepublishOnly": "bun run check && bun run build",
    "example:basic": "bun run examples/basic.ts",
    "example:transfer": "bun run examples/transfer.ts",
    "example:claude": "bun run examples/claude-agent.ts",
    "example:tools": "bun run examples/direct-tools.ts",
    "example:platform": "bun run examples/platform.ts",
    "example:openapi": "bun run examples/openapi-generated.ts",
    "example:user-email-flow": "bun run examples/user-email-flow.ts",
    "example:per-user-agents": "bun run examples/per-user-agents.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "clipboardy": "^4.0.0",
    "commander": "^14.0.3",
    "open": "^10.1.0",
    "posthog-node": "^5.28.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.25.0",
    "@types/bun": "^1.3.2",
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "keywords": [
    "wallet",
    "ai",
    "agent",
    "claude",
    "mcp",
    "crypto",
    "ethereum",
    "solana"
  ],
  "license": "MIT",
  "homepage": "https://docs.paysponge.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/paysponge/sponge.git",
    "directory": "mobwallet/packages/spongewallet-sdk"
  },
  "bugs": {
    "url": "https://github.com/paysponge/sponge/issues"
  }
}
